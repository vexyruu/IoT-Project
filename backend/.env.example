# OpenSky Network credentials (optional but recommended to avoid HTTP 429)
# Register free at: https://opensky-network.org/index.php?option=com_users&view=registration
OPENSKY_USER=your_opensky_username
OPENSKY_PASS=your_opensky_password

# SQLite database path (default: backend/data/flights.db)
# On Fly.io this is set automatically to /data/flights.db via fly.toml
# DB_PATH=/data/flights.db

# API server port (default: 3000)
# PORT=3000
